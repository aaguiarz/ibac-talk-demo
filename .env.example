# Required
ANTHROPIC_API_KEY=sk-ant-...

# OpenFGA — set automatically by `make openfga-setup` / `make fga-reset`
FGA_STORE_ID=
FGA_API_URL=http://localhost:8080

# Optional
# ANTHROPIC_MODEL=claude-haiku-4-5          # Default model
# FGA_USER_ID=default                       # User identity for FGA tuples (from access token in production)
# FGA_AGENT_ID=mcp_agent                    # Agent identity for FGA tuples (from client credentials in production)
# MCP_TOOL_TIMEOUT_SECONDS=90               # Timeout for MCP tool calls via the agent
# MCP_REMOTE_TOOL_TIMEOUT_SECONDS=90        # Timeout for remote MCP server calls
# MCP_SERVER=src/mcp_server.py              # Custom MCP server script path
# MCP_SSL_VERIFY=false                      # Disable TLS verification (dev only, e.g. corporate VPN)
# MCP_SSL_CA_BUNDLE=/path/to/ca-bundle.crt  # Custom CA bundle for remote MCP servers
# LOG_LEVEL=verbose                         # verbose | debug
